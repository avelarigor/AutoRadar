# ── Credenciais e configuração sensível ──────────────────────────────────────
.env
telegram_config.json

# ── Perfis de browser (cookies, sessões) ──────────────────────────────────────
profiles/

# ── Logs ──────────────────────────────────────────────────────────────────────
logs/
*.log

# ── Cache Python ──────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo

# ── Ambientes virtuais ────────────────────────────────────────────────────────
.venv/
venv/

# ── Arquivos de lixo / legado ─────────────────────────────────────────────────
trash/
desktop.ini

# ── Bancos de dados (mudam frequentemente, não versionados) ──────────────────
data/cache/
data/*.db
data/*.db-journal
data/*.db-wal
data/*.db-shm

# ── VS Code ───────────────────────────────────────────────────────────────────
.vscode/

# ── Exemplos mantidos no repo (não ignorar) ───────────────────────────────────
